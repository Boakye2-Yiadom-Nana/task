<%= form_with(model: todo_task, html: { class: "category-form" }) do |form| %>
  <% if todo_task.errors.any? %>
    <div class="error-messages">
      <h2><%= pluralize(todo_task.errors.count, "error") %> prohibited this task from being saved:</h2>
      <ul>
        <% todo_task.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-input" %>
  </div>

  <div class="form-field">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, class: "form-textarea" %>
  </div>

  <div class="form-field">
    <%= form.label :due_date, class: "form-label" %>
    <%= form.datetime_local_field :due_date, class: "form-input" %>
  </div>

  <div class="form-field">
    <%= form.label :status, class: "form-label" %>
    <%= form.select :status, ['pending', 'in-progress', 'completed'], {}, { class: "form-input" } %>
  </div>
  <div class="form-field">
     <%= form.label :priority, class: "form-label" %>
     <%= form.select :priority, TodoTask::PRIORITIES.map {|p| [p.titleize, p] }, {include_blank: "Slect priorty" }, { class: "form-input" } %>

  </div>

  <div class="form-field">
    <%= form.label :category_id, "Category", class: "form-label" %>
    <%= form.collection_select :category_id, Category.all, :id, :name,
          { prompt: "select a category" },
          { class: "form-input" } %>
  </div>

  <div class= "form-field">
  <%= form.label :attachments, class: "form-label" %>
  <%= form.file_field :attachments, multiple: true, class: "form-input" %>

  </div>

  <div class="form-actions">
    <%= form.submit "Save Task", class: "btn-submit" %>
  </div>
<% end %>
