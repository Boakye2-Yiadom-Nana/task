<h1 class="page-title"><%= @category.name %></h1>

<div class="category-details">
  <p class="detail-item">
    <strong class="detail-label">Description:</strong>
    <span class="detail-value"><%= @category.description %></span>
  </p>
</div>

<h2 class="section-title">Tasks in this category</h2>

<table class="tasks-table">
  <thead>
    <tr>
      <th class="table-header">Title</th>
      <th class="table-header">Status</th>
      <th class="table-header">Due Date</th>
      <th class="table-header">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @todo_tasks.each do |task| %>
      <tr class="task-row">
        <td class="task-cell"><%= task.title %></td>
        <td class="task-cell"><%= task.status %></td>
        <td class="task-cell"><%= task.due_date %></td>
        <td class="task-actions">
          <%= link_to 'View', todo_task_path(task), class: "btn btn-view" %>
          <%= link_to 'Edit', edit_todo_task_path(task), class: "btn btn-edit" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="actions-bar">
  <%= link_to 'Edit Category', edit_category_path(@category), class: "btn btn-edit" %>
  <%= link_to 'Back to Categories', categories_path, class: "btn btn-secondary" %>
</div>
